---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import TagFilter from "../../components/TagFilter.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sorted = projects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort();
---

<Base title="Projects — Steve Kuo" description="Things I've built.">
  <section class="py-8">
    <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
      Projects
    </h1>
    <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
      Things I've built or am building.
    </p>
  </section>

  <TagFilter tags={allTags} />

  <div>
    {
      sorted.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          slug={project.id}
          repo={project.data.repo}
          live={project.data.live}
          status={project.data.status}
        />
      ))
    }
  </div>
</Base>
