---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
});
---

<a
  href={`/blog/${slug}`}
  class="filterable-item group block py-3"
  data-tags={tags.join(",")}
>
  <div class="flex items-baseline justify-between gap-4">
    <span class="font-medium text-neutral-900 group-hover:text-slate-600 dark:text-neutral-100 dark:group-hover:text-slate-400">
      {title}
    </span>
    <span class="shrink-0 font-mono text-xs text-neutral-400 dark:text-neutral-500">
      {formattedDate}
    </span>
  </div>
  <p class="mt-0.5 text-sm text-neutral-500 dark:text-neutral-400">
    {description}
  </p>
</a>
