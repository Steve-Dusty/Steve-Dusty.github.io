---
interface Props {
  maxWidth?: "2xl" | "3xl" | "4xl" | "5xl";
}

const { maxWidth = "2xl" } = Astro.props;
const widthMap = {
  "2xl": "max-w-2xl",
  "3xl": "max-w-3xl",
  "4xl": "max-w-4xl",
  "5xl": "max-w-5xl",
};
const widthClass = widthMap[maxWidth];

const navLinks = [
  { href: "/", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Writing" },
];

const currentPath = Astro.url.pathname;
---

<header
  class={`mx-auto flex ${widthClass} items-baseline justify-between gap-6 px-6 pt-8 pb-2 font-sans`}
>
  <a
    href="/"
    class="text-sm font-medium tracking-tight text-neutral-900 dark:text-neutral-100"
  >
    Steve Kuo
  </a>
  <nav class="flex items-baseline gap-5 text-sm">
    {
      navLinks.map(({ href, label }) => {
        const active =
          href === "/" ? currentPath === "/" : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              "transition-colors",
              active
                ? "text-neutral-900 dark:text-neutral-100"
                : "text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100",
            ]}
          >
            {label}
          </a>
        );
      })
    }
    <button
      id="theme-toggle"
      class="text-neutral-400 transition-colors hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-100"
      aria-label="Toggle dark mode"
    >
      <svg class="dark-icon hidden h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
      </svg>
      <svg class="light-icon hidden h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
      </svg>
    </button>
  </nav>
</header>

<script>
  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;

    function updateIcons() {
      const isDark = document.documentElement.classList.contains("dark");
      btn!.querySelector(".dark-icon")!.classList.toggle("hidden", !isDark);
      btn!.querySelector(".light-icon")!.classList.toggle("hidden", isDark);
    }

    updateIcons();

    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateIcons();
    });
  }

  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
