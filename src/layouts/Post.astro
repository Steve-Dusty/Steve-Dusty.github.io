---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={title} description={description}>
  <article class="py-8">
    <header class="mb-10">
      <p class="mb-2 font-mono text-sm text-neutral-500 dark:text-neutral-400">
        {formattedDate}
      </p>
      <h1 class="text-2xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        {title}
      </h1>
      {
        tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 font-mono text-xs text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose dark:prose-invert">
      <slot />
    </div>
  </article>
</Base>
